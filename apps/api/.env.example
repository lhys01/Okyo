# ─── AI provider ─────────────────────────────────────────────────────────────
# Set AI_ENABLED=true to enable real OpenRouter AI calls.
# Leave false in dev until you want to spend real API credits.
AI_ENABLED=false
AI_PROVIDER=openrouter
# Private key — backend only. Never put this in mobile code or commit to git.
OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
OPENROUTER_TEXT_MODEL=openai/gpt-4o-mini
AI_TIMEOUT_MS=45000
AI_MAX_OUTPUT_TOKENS=1024

# ─── Fable 5 (opt-in, via OpenRouter — not a separate SDK) ───────────────────
# Set FABLE_ENABLED=true to allow the private `x-okyo-model: fable` request
# header to route a scan through Fable 5 instead of the default OpenRouter
# model. Off by default — normal OpenRouter/gpt-4o-mini path is unaffected.
FABLE_ENABLED=false
FABLE_MODEL=anthropic/claude-fable-5
# Hard-clamped to 10 in code even if this is set higher.
FABLE_DAILY_REQUEST_CAP=10

# ─── Epicure ingredient intelligence (additive enrichment layer) ─────────────
# Set EPICURE_ENABLED=true to enrich recipe prompts with ingredient pairings and
# healthy/budget substitutions BEFORE recipe generation. When false (or no key),
# recipe generation behaves exactly as before. Reuses OPENROUTER_API_KEY above.
EPICURE_ENABLED=false
# Food-intelligence model used only by Epicure (separate from the vision/text
# models). Defaults to openai/gpt-4o-mini if unset.
OPENROUTER_MODEL=openai/gpt-4o-mini
# Recipe cache TTL in days (default 7). Set to 0 to disable.
RECIPE_CACHE_TTL_DAYS=7
# How long an Epicure request may run before falling back to plain generation.
EPICURE_TIMEOUT_MS=12000

# ─── Cost controls ───────────────────────────────────────────────────────────
# Set AI_ENABLED=false to kill all AI immediately.
# AI_DAILY_REQUEST_CAP: max real AI scan calls per day (in-memory, resets on restart).
AI_DAILY_REQUEST_CAP=200
# MAX_SCAN_IMAGE_BYTES: max allowed image payload in bytes (default 10 MB).
MAX_SCAN_IMAGE_BYTES=10000000
# SCAN_RATE_LIMIT_WINDOW_MS: sliding window duration in ms for per-IP rate limit.
SCAN_RATE_LIMIT_WINDOW_MS=60000
# SCAN_RATE_LIMIT_MAX: max scan requests per IP per window.
SCAN_RATE_LIMIT_MAX=10

# ─── Image generation (future feature, currently disabled) ───────────────────
# Set IMAGE_GEN_ENABLED=true when image generation is wired up.
IMAGE_GEN_ENABLED=false
IMAGE_GEN_DAILY_REQUEST_CAP=0
