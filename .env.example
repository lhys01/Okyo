# ─── AI provider (backend only) ──────────────────────────────────────────────
# Private keys must NEVER go in mobile app code or be committed to git.
OPENAI_API_KEY=
AI_ENABLED=false
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
OPENROUTER_TEXT_MODEL=openai/gpt-4o-mini
AI_TIMEOUT_MS=30000
AI_MAX_OUTPUT_TOKENS=4096

# ─── Cost controls (backend only) ────────────────────────────────────────────
# Emergency AI kill switch: set AI_ENABLED=false to stop all AI calls immediately.
AI_DAILY_REQUEST_CAP=200
MAX_SCAN_IMAGE_BYTES=10000000
SCAN_RATE_LIMIT_WINDOW_MS=60000
SCAN_RATE_LIMIT_MAX=10

# ─── Image generation kill switch (scaffold for future feature) ───────────────
IMAGE_GEN_ENABLED=false
IMAGE_GEN_DAILY_REQUEST_CAP=0

# ─── Services ─────────────────────────────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY is private — backend only, never in mobile.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
REVENUECAT_PUBLIC_KEY=
POSTHOG_API_KEY=

# ─── Mobile (public, safe to expose in app bundle) ───────────────────────────
EXPO_PUBLIC_API_URL=
